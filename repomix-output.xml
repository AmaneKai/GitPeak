        >
          <Orbit size={10} />
          <span>Orbit</span>
        </Button>
      </div>
    </div>
  </CardHeader>

  <CardContent class="p-4 pt-4 sm:p-5">
    <!-- Items-start keeps positions anchored independently of dynamic height shifts -->
    <div
      class="flex flex-col items-center justify-center gap-5 sm:flex-row sm:items-start sm:gap-5"
    >
      <div class="relative shrink-0" style="width:{SIZE}px; height:{SIZE}px;">
        <!-- Background Vector Layer -->
        <svg
          width={SIZE}
          height={SIZE}
          viewBox="0 0 {SIZE} {SIZE}"
          class="pointer-events-auto absolute inset-0 overflow-visible"
        >
          <defs>
            {#each pie.slices as slice, index (slice.name || index)}
              <filter id="lp-glow-{index}" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur" />
                <feFlood flood-color={slice.color} flood-opacity="0.5" result="clr" />
                <feComposite in="clr" in2="blur" operator="in" result="glow" />
                <feMerge>
                  <feMergeNode in="glow" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            {/each}
          </defs>

          <!-- BASELINE RING -->
          <circle
            cx={CX}
            cy={CY}
            r={(R_OUTER + R_INNER) / 2}
            fill="none"
            stroke="rgba(144,140,170,0.05)"
            stroke-width={R_OUTER - R_INNER + 1}
          />

          <!-- ================= VIEW 1: LANGUAGE PIE ================= -->
          <g
            class="lang-path-group"
            style="
							opacity: {viewMode === 'languages' ? '1' : '0'}; 
							pointer-events: {viewMode === 'languages' ? 'auto' : 'none'};
						"
          >
            {#each pie.animatedSlices as slice, index (slice.name || index)}
              {@const off = pie.hovered === index ? segOffset(slice) : { x: 0, y: 0 }}
              <path
                d={arcPath(CX, CY, R_OUTER, R_INNER, slice.startDeg, slice.endDeg, off.x, off.y)}
                fill={slice.color}
                class="arc-path"
                class:dimmed={pie.hovered !== null && pie.hovered !== index}
                style="filter:{pie.hovered === index ? `url(#lp-glow-${index})` : 'none'};"
                onmouseenter={() => pie.onEnter(index)}
                onmouseleave={pie.onLeave}
                ontouchstart={() => pie.onEnter(index)}
                ontouchend={pie.onLeave}
                role="presentation"
              />
            {/each}
          </g>

          <!-- ================= VIEW 2: RECENCY ORBIT ================= -->
          <g
            class="orbit-path-group"
            style="
							opacity: {viewMode === 'orbit' ? '1' : '0'}; 
							pointer-events: {viewMode === 'orbit' ? 'auto' : 'none'};
						"
          >
            <!-- Concentric Guides -->
            <circle
              cx={CX}
              cy={CY}
              r={R_INNER + 10}
              fill="none"
              stroke="var(--subtle)"
              stroke-opacity="0.08"
              stroke-dasharray="2 3"
            />
            <circle
              cx={CX}
              cy={CY}
              r={(R_INNER + R_OUTER) / 2 + 5}
              fill="none"
              stroke="var(--subtle)"
              stroke-opacity="0.06"
              stroke-dasharray="2 3"
            />
            <circle
              cx={CX}
              cy={CY}
              r={R_OUTER + 12}
              fill="none"
              stroke="var(--subtle)"
              stroke-opacity="0.04"
              stroke-dasharray="2 3"
            />

            <!-- Connecting Guides -->
            {#each mappedOrbitNodes as node, index (node.owner + '/' + node.name)}
              {@const isActive = hoveredOrbitNode === index}
              {#if isActive}
                <circle
                  cx={CX}
                  cy={CY}
                  r={node.radius}
                  fill="none"
                  stroke={node.langColor}
                  stroke-opacity="0.15"
                  stroke-width="1"
                  class="fade-in"
                />
                <line
                  x1={CX}
                  y1={CY}
                  x2={node.x}
                  y2={node.y}
                  stroke={node.langColor}
                  stroke-width="1"
                  stroke-dasharray="2 2"
                  stroke-opacity="0.25"
                  class="fade-in"
                />
              {/if}
            {/each}

            <!-- Repository Nodes -->
            {#each mappedOrbitNodes as node, index (node.owner + '/' + node.name)}
              {@const isActive = hoveredOrbitNode === index}
              <g
                role="button"
                class="cursor-pointer select-none"
                onmouseenter={() => (hoveredOrbitNode = index)}
                onmouseleave={() => (hoveredOrbitNode = null)}
                onclick={() => window.open(node.url, '_blank')}
                onkeydown={(e) => {
                  if (e.key === 'Enter' || e.key === ' ') 
                    window.open(node.url, '_blank')
                }}
                tabindex="0"
                aria-label="View {node.name} repository"
              >
                <circle
                  cx={node.x}
                  cy={node.y}
                  r={isActive ? node.haloSize + 2 : node.haloSize}
                  fill={node.langColor}
                  fill-opacity={isActive ? 0.28 : 0.08}
                  style="transition: r 0.2s cubic-bezier(0.25, 1, 0.5, 1), fill-opacity 0.2s ease;"
                />
                <circle
                  cx={node.x}
                  cy={node.y}
                  r={isActive ? node.coreSize + 1 : node.coreSize}
                  fill={node.langColor}
                  style="transition: r 0.2s cubic-bezier(0.25, 1, 0.5, 1);"
                />
              </g>
            {/each}
          </g>

          <!-- Subtle Context-Aware Outer Ring -->
          <circle
            cx={CX}
            cy={CY}
            r={R_INNER - 2}
            fill="none"
            stroke-width="1.5"
            style="
							stroke: {pie.hovered !== null || (viewMode === 'orbit' && hoveredOrbitNode !== null)
							  ? currentActiveColor
							  : 'rgba(196,167,231,0.18)'};
							stroke-opacity: {isPfpHovered ? 0.5 : 0.2};
							transition: stroke 0.2s ease, stroke-opacity 0.2s ease;
						"
          />
        </svg>

        <!-- ================= FOREGROUND NATIVE HTML OVERLAYS ================= -->
        <!-- added "group" class to allow dynamic child hover selection -->
        <button
          type="button"
          onclick={() => (viewMode = viewMode === 'languages' ? 'orbit' : 'languages')}
          onmouseenter={() => (isPfpHovered = true)}
          onmouseleave={() => (isPfpHovered = false)}
          class="bg-base group pfp-button-group absolute flex cursor-pointer items-center justify-center overflow-hidden rounded-full border-none shadow-md outline-none select-none"
          style="width: {R_AVATAR_SIZE}px; height: {R_AVATAR_SIZE}px; top: {leftOffset}px; left: {leftOffset}px;"
          aria-label="Toggle view mode"
        >
          <!-- after:hidden strips default shadcn white inner-rings -->
          <!-- transition handled cleanly via Tailwind group-hover modifiers -->
          <Avatar.Root
            class="absolute inset-0 h-full w-full transition-all duration-300 group-hover:brightness-[1.05] group-active:brightness-[0.95] after:hidden"
            style="width: 100%; height: 100%;"
          >
            <Avatar.Image src={avatarUrl} alt="User avatar" />
            <Avatar.Fallback
              class="text-muted-foreground bg-muted flex items-center justify-center font-mono text-xs"
              >GP</Avatar.Fallback
            >
          </Avatar.Root>

          <!-- View 1: Language details inside Center -->
          {#if viewMode === 'languages' && pie.hovered !== null && pie.slices[pie.hovered]}
            {@const s = pie.slices[pie.hovered]}
            <div
              class="bg-base/85 fade-in pointer-events-none absolute inset-0.75 flex flex-col items-center justify-center rounded-full p-1.5 text-center"
            >
              <span
                class="max-w-full truncate px-1 font-mono text-[9px] tracking-widest uppercase"
                style="color: {s.color}">{s.name}</span
              >
              <span class="text-text mt-0.5 font-serif text-lg leading-none font-bold"
                >{s.percentage}%</span
              >
            </div>
          {/if}

          <!-- View 2: Orbit details inside Center -->
          {#if viewMode === 'orbit' && hoveredOrbitNode !== null && mappedOrbitNodes[hoveredOrbitNode]}
            {@const node = mappedOrbitNodes[hoveredOrbitNode]}
            <div
              class="bg-base/90 fade-in pointer-events-none absolute inset-0.75 flex flex-col items-center justify-center rounded-full p-1.5 text-center"
            >
              <span
                class="text-muted max-w-full truncate px-1 font-mono text-[8px] tracking-wider uppercase"
                >@{node.owner}</span
              >
              <span
                class="text-text mt-0.5 max-w-full truncate px-1 font-mono text-[10px] leading-tight font-semibold"
                >{node.name}</span
              >
              <span class="mt-0.5 font-mono text-[9px] font-medium" style="color: {node.langColor}"
                >{node.relativeLabel}</span
              >
            </div>
          {/if}
        </button>
      </div>

      <!-- ================= LEGEND CONTENT BLOCK ================= -->
      <div class="flex w-full flex-col gap-3">
        {#if viewMode === 'languages'}
          <ul
            class="legend-list flex w-full flex-col gap-0.5"
            class:fade-in={viewMode === 'languages'}
          >
            {#each pie.slices as slice, index (slice.name || index)}
              {@const url = langIconUrl(slice.name)}
              {@const active = pie.hovered === index}
              <li
                class="lang-row"
                class:active
                style="background:{active
                  ? `${slice.color}12`
                  : 'transparent'}; animation-delay:{index * 30}ms;"
                onmouseenter={() => pie.onEnter(index)}
                onmouseleave={pie.onLeave}
                ontouchstart={() => pie.onEnter(index)}
                ontouchend={pie.onLeave}
              >
                <span
                  class="icon-badge"
                  style="
										background:{slice.color}1a;
										border:1px solid {slice.color}{active ? '48' : '20'};
									"
                >
                  {#if url}
                    <img
                      src={url}
                      alt={slice.name}
                      width="13"
                      height="13"
                      onerror={hideImgOnError}
                    />
                    <span
                      style="
                      display:none;
                      width:7px;
                      height:7px;
                      border-radius:50%;
                      background:{slice.color};"
                    ></span>
                  {:else}
                    <span style="width:7px;height:7px;border-radius:50%;background:{slice.color};"
                    ></span>
                  {/if}
                </span>

                <span
                  class="flex-1 truncate"
                  style="
										font-family:'DM Mono',monospace;font-size:11px;
										letter-spacing:0.01em;transition:color 0.15s ease;
										color:{active ? slice.color : 'var(--text)'};
										font-weight:{active ? 500 : 400};
									">{slice.name}</span
                >

                <div
                  class="shrink-0 overflow-hidden rounded-full"
                  style="
                  width:60px; 
                  height:3px; 
                  background:color-mix(in srgb, var(--subtle) 10%, transparent);"
                >
                  <div
                    class="bar-grow h-full rounded-full"
                    style="
											width:{slice.percentage}%;
											background:{slice.color};
											opacity:{active ? 1 : 0.55};
											animation-delay:{index * 20}ms;
										"
                  ></div>
                </div>

                <span
                  class="shrink-0 text-right"
                  style="
										font-family:'DM Mono',monospace;font-size:10.5px;width:28px;
										transition:color 0.15s ease;
										color:{active ? slice.color : 'var(--muted)'};
										font-weight:{active ? 600 : 400};
									">{slice.percentage}%</span
                >
              </li>
            {/each}
          </ul>
        {:else}
          <div
            class="legend-list flex w-full flex-col gap-0.5"
            class:fade-in={viewMode === 'orbit'}
          >
            <div
              class="px-2 pb-1.5 font-mono text-[9px] tracking-wider uppercase"
              style="color: var(--muted)"
            >
              Recent Activity ({mappedOrbitNodes.length})
            </div>
            {#each mappedOrbitNodes as node, index (node.owner + '/' + node.name)}
              {@const active = hoveredOrbitNode === index}
              <button
                type="button"
                class="lang-row w-full cursor-pointer text-left"
                class:active
                style="
									background:{active ? `${node.langColor}12` : 'transparent'}; 
									animation-delay:{index * 30}ms;
								"
                onmouseenter={() => (hoveredOrbitNode = index)}
                onmouseleave={() => (hoveredOrbitNode = null)}
                onclick={() => window.open(node.url, '_blank')}
              >
                <span
                  class="icon-badge"
                  style="
										background:{node.langColor}1a;
										border:1px solid {node.langColor}{active ? '48' : '20'};
									"
                >
                  <span style="width:7px;height:7px;border-radius:50%;background:{node.langColor};"
                  ></span>
                </span>

                <div class="flex min-w-0 flex-1 flex-col">
                  <span
                    class="truncate"
                    style="
											font-family:'DM Mono',monospace;font-size:11px;
											transition:color 0.15s ease;
											color:{active ? node.langColor : 'var(--text)'};
											font-weight: 500;
										"
                  >
                    {node.name}
                  </span>
                  <span class="truncate text-[9px]" style="color: var(--muted)">
                    {node.owner} &nbsp;·&nbsp; {node.primaryLanguage || 'Code'}
                  </span>
                </div>

                <span
                  class="shrink-0 text-right font-mono text-[10px] transition-colors duration-150"
                  style="color: {active ? node.langColor : 'var(--subtle)'}"
                >
                  {node.relativeLabel}
                </span>
              </button>
            {/each}
          </div>
        {/if}
      </div>
    </div>
  </CardContent>
</Card>

