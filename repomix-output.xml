@import "tailwindcss";

@theme {
  --color-base: var(--base);
  --color-surface: var(--surface);
  --color-overlay: var(--overlay);
  --color-muted: var(--muted);
  --color-subtle: var(--subtle);
  --color-text: var(--text);
  
  --color-love: var(--love);
  --color-gold: var(--gold);
  --color-rose: var(--rose);
  --color-pine: var(--pine);
  --color-foam: var(--foam);
  --color-iris: var(--iris);
  
  --color-highlight-low: var(--highlight-low);
  --color-highlight-med: var(--highlight-med);
  --color-highlight-high: var(--highlight-high);

  --color-background: var(--base);
  --color-foreground: var(--text);
  --color-primary: var(--iris);
  --color-primary-foreground: var(--base);
  --color-secondary: var(--highlight-med);
  --color-secondary-foreground: var(--text);
  --color-border: var(--highlight-low);
  --color-muted-foreground: var(--subtle);
  
  --color-accent: var(--theme-accent);

  --font-family-mono: "DM Mono", "JetBrains Mono", monospace;
  --font-family-serif: "Instrument Serif", serif;
}

@layer base {
  :root,
  [data-theme="Rosé Pine"] {
    --base: #191724;
    --surface: #1f1d2e;
    --overlay: #26233a;
    --muted: #6e6a86;
    --subtle: #908caa;
    --text: #e0def4;
    --love: #eb6f92;
    --gold: #f6c177;
    --rose: #ebbcba;
    --pine: #31748f;
    --foam: #9ccfd8;
    --iris: #c4a7e7;
    --highlight-low: #21202e;
    --highlight-med: #403d52;
    --highlight-high: #524f67;
  }

  [data-theme="Rosé Pine Moon"] {
    --base: #232136;
    --surface: #2a273f;
    --overlay: #393552;
    --muted: #6e6a86;
    --subtle: #908caa;
    --text: #e0def4;
    --love: #eb6f92;
    --gold: #f6c177;
    --rose: #ea9a97;
    --pine: #3e8fb0;
    --foam: #9ccfd8;
    --iris: #c4a7e7;
    --highlight-low: #2a283e;
    --highlight-med: #44415a;
    --highlight-high: #56526e;
  }

  [data-theme="Rosé Pine Dawn"] {
    --base: #faf4ed;
    --surface: #fffaf3;
    --overlay: #f2e9e1;
    --muted: #9893a5;
    --subtle: #797593;
    --text: #575279;
    --love: #b4637a;
    --gold: #ea9d34;
    --rose: #d7827a;
    --pine: #286983;
    --foam: #56949f;
    --iris: #907aa9;
    --highlight-low: #f4ede8;
    --highlight-med: #dfdad9;
    --highlight-high: #cecacd;
  }

  [data-theme="Catppuccin Mocha"] {
    --base: #1e1e2e;
    --surface: #181825;
    --overlay: #313244;
    --muted: #6c7086;
    --subtle: #a6adc8;
    --text: #cdd6f4;
    --love: #f38ba8;
    --gold: #f9e2af;
    --rose: #f5c2e7;
    --pine: #89b4fa;
    --foam: #89dceb;
    --iris: #cba6f7;
    --highlight-low: #1e1e2e;
    --highlight-med: #313244;
    --highlight-high: #45475a;
  }

  [data-theme="Catppuccin Latte"] {
    --base: #eff1f5;
    --surface: #e6e9ef;
    --overlay: #dce0e8;
