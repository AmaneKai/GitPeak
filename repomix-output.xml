	--highlight-high: #4c566a;
}

* {
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
	-webkit-text-size-adjust: 100%;
	text-size-adjust: 100%;
}

body {
	font-family: "JetBrains Mono", monospace;
	background: var(--base);
	color: var(--text);
	overflow-x: hidden;
	padding-left: env(safe-area-inset-left);
	padding-right: env(safe-area-inset-right);
	padding-top: env(safe-area-inset-top);
	padding-bottom: env(safe-area-inset-bottom);
}

/* ── Aurora background ───────────────────────────────────────────────────── */
.aurora-bg {
	position: fixed;
	inset: 0;
	z-index: -1;
	background: var(--base);
	overflow: hidden;
}

.aurora-bg::before,
.aurora-bg::after {
	content: "";
	position: absolute;
	border-radius: 50%;
	filter: blur(120px);
	animation: drift 25s ease-in-out infinite;
}

.aurora-bg::before {
	width: 70vw;
	height: 70vw;
	top: -20%;
	left: -10%;
	background: radial-gradient(
		circle,
		color-mix(in srgb, var(--iris) 12%, transparent) 0%,
		transparent 70%
	);
	animation-duration: 20s;
}

.aurora-bg::after {
	width: 60vw;
	height: 60vw;
	bottom: -15%;
	right: -10%;
	background: radial-gradient(
		circle,
		color-mix(in srgb, var(--foam) 10%, transparent) 0%,
		transparent 70%
	);
	animation-duration: 28s;
	animation-direction: reverse;
}

@keyframes drift {
	0%,
	100% {
		transform: translate(0, 0) scale(1);
	}
	33% {
		transform: translate(40px, -60px) scale(1.08);
	}
	66% {
		transform: translate(-30px, 40px) scale(0.95);
	}
}

/* ── Glass card ──────────────────────────────────────────────────────────── */
.glass {
	background: color-mix(in srgb, var(--surface) 60%, transparent);
	backdrop-filter: blur(20px) saturate(160%);
	-webkit-backdrop-filter: blur(20px) saturate(160%);
	border: 1px solid color-mix(in srgb, var(--subtle) 15%, transparent);
	box-shadow:
		0 1px 0 0 color-mix(in srgb, var(--text) 6%, transparent) inset,
		0 32px 64px -16px rgba(0, 0, 0, 0.45);
}

/* ── Gradient text ───────────────────────────────────────────────────────── */
.gradient-text {
	color: var(--iris);
	background: linear-gradient(135deg, var(--iris) 0%, var(--foam) 50%, var(--rose) 100%);
	-webkit-background-clip: text;
	background-clip: text;
	-webkit-text-fill-color: transparent;
}

/* ── Tilt card ───────────────────────────────────────────────────────────── */
.tilt-card {
	will-change: transform;
	transition:
		transform 0.1s ease,
		box-shadow 0.1s ease,
		border-color 0.1s ease;
	touch-action: manipulation;
}

.tilt-shine {
	pointer-events: none;
	position: absolute;
	inset: 0;
	border-radius: inherit;
}

/* ── Animations ──────────────────────────────────────────────────────────── */
@keyframes fadeInUp {
	from {
		opacity: 0;
		transform: translateY(16px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.fade-in-up {
	animation: fadeInUp 0.5s ease both;
}

@keyframes shimmer {
	0% {
		transform: translateX(-100%);
	}
	100% {
		transform: translateX(400%);
	}
}

.shimmer {
	position: relative;
	overflow: hidden;
	isolation: isolate;
}

.shimmer::after {
	content: "";
	position: absolute;
	top: 0;
	bottom: 0;
	left: 0;
	width: 25%;
	background: linear-gradient(
		90deg,
		transparent 0%,
		color-mix(in srgb, var(--iris) 11%, transparent) 40%,
		color-mix(in srgb, var(--text) 15%, transparent) 50%,
		color-mix(in srgb, var(--iris) 11%, transparent) 60%,
		transparent 100%
	);
	animation: shimmer 2s ease-in-out infinite;
	pointer-events: none;
}

@keyframes barGrow {
	from {
		clip-path: inset(0 100% 0 0);
	}
	to {
		clip-path: inset(0 0% 0 0);
	}
}

.bar-grow {
	animation: barGrow 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes pulseDot {
	0%,
	100% {
		opacity: 1;
		transform: scale(1);
	}
	50% {
		opacity: 0.4;
		transform: scale(0.8);
	}
}

.pulse-dot {
	animation: pulseDot 1.4s ease-in-out infinite;
}

/* ── Scrollbar ───────────────────────────────────────────────────────────── */
::-webkit-scrollbar {
	width: 6px;
}
::-webkit-scrollbar-track {
	background: transparent;
}
::-webkit-scrollbar-thumb {
	background: var(--highlight-med);
	border-radius: 99px;
}
