							${stats.displayName || username}
						</div>
						<div style="display: flex; font-size: 20px; color: #908caa; margin-top: 8px;">@${username}</div>
					</div>
				</div>

				<div style="display: flex; flex-wrap: wrap; gap: 16px; width: 100%;">
