			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media = 'all'"
			crossorigin="anonymous"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&display=swap"
				rel="stylesheet"
				crossorigin="anonymous"
			/>
		</noscript>

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta property="og:site_name" content="GitPeak" />
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "GitPeak",
			"url": "https://gitpeak.vercel.app/"
		}
		</script>
		<title>GitPeak</title>
		<script>
			try {
				var n = localStorage.getItem("gitpeak-theme")
				if (n === "custom") {
					var raw = localStorage.getItem("gitpeak-theme-tokens")
					if (raw) {
						var tok = JSON.parse(raw),
							r = document.documentElement
						for (var k in tok) r.style.setProperty("--" + k, tok[k])
					}
				} else if (n) {
					document.documentElement.setAttribute("data-theme", n)
				}
			} catch (e) {}
		</script>
		%sveltekit.head%
	</head>
	<body data-sveltekit-preload-data="hover">
		<div style="display: contents">%sveltekit.body%</div>
	</body>
</html>
