			rel="stylesheet"
			media="print"
			onload="this.media = 'all'"
			crossorigin="anonymous"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&display=swap"
				rel="stylesheet"
				crossorigin="anonymous"
			/>
		</noscript>

		<!-- Instrument Serif & DM Mono -->
