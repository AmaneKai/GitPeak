          {viewMode === 'languages' ? 'Languages' : 'Recency Orbit'}
        </span>
      </div>

      <div class="flex items-center gap-1 rounded-lg p-0.5" style="background: rgba(0,0,0,0.12)">
        <Button
          variant={viewMode === 'languages' ? 'secondary' : 'ghost'}
