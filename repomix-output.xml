<file path="src/lib/entities/github/ui/LanguagePie.svelte">
<script lang="ts">
  import { type GitHubLanguage, type InvolvedRepo } from '$lib/entities/github/model/github-stats'
  import { useLanguagePie, arcPath, segOffset } from './useLanguagePie.svelte'
  import { langIconUrl, hideImgOnError } from '$lib/shared/utils/icons'
  import { Button } from '$lib/shared/ui/button'
  import { Card, CardContent, CardHeader } from '$lib/shared/ui/card'
  import { pickAccentColor } from '$lib/shared/utils/theme'
  import * as Avatar from '$lib/shared/ui/avatar'
  import { Orbit, Palette } from 'lucide-svelte'

  let {
    languages,
    avatarUrl,
    involvedRepos = [],
  }: {
    languages: GitHubLanguage[]
    avatarUrl: string
    involvedRepos?: InvolvedRepo[]
  } = $props()

  const activeRepos = $derived(involvedRepos.length > 0 ? involvedRepos : [])

  let viewMode = $state<'languages' | 'orbit'>('languages')
  let hoveredOrbitNode = $state<number | null>(null)
  let isPfpHovered = $state(false)

  const pie = useLanguagePie(() => languages)
  const { SIZE, CX, CY, R_OUTER, R_INNER } = pie.dims

  // Exact circular size calculation for the central Avatar button
  const R_AVATAR_SIZE = $derived((R_INNER - 3.5) * 2)

  // Perfectly centers the absolute HTML button over the SVG baseline coordinates
  const leftOffset = $derived((SIZE - R_AVATAR_SIZE) / 2)

  // Deterministic client-side color mapper
  const getLanguageColor = (langName: string | null | undefined): string => {
    if (!langName) 
      return 'var(--iris)'

    // 1. Match the color of the language's slice in the pie chart
    const index = languages.findIndex((l) => l.name.toLowerCase() === langName.toLowerCase())
    if (index !== -1) 
      return pickAccentColor(index)

    // 2. Generate a stable, deterministic color hash if it's not in the main languages list
    let hash = 0
    for (let index_ = 0; index_ < langName.length; index_++)
      hash = langName.charCodeAt(index_) + ((hash << 5) - hash)

    return pickAccentColor(Math.abs(hash))
  }

  // Chronological Distancing Logic
  const mappedOrbitNodes = $derived.by(() => {
    if (activeRepos.length === 0) 
      return []

    // Sort all repositories by chronological recency (newest first)
    const parsed = activeRepos
      .map((repo) => ({
        ...repo,
        timeValue: Date.parse(repo.lastContributedAt),
      }))
      .sort((a, b) => b.timeValue - a.timeValue)

    const now = Date.now()
    const dates = parsed.map((r) => r.timeValue)
    const newest = Math.max(...dates)
    const oldest = Math.min(...dates)
    const span = newest - oldest || 1

    const minRadius = R_INNER + 10
    const maxRadius = R_OUTER + 12

    // Dynamically scale core nodes based on dataset density
    const count = parsed.length
    const coreSize = Math.max(1.8, Math.min(3.5, 24 / count))
    const haloSize = coreSize * 2

    return parsed.map((repo, index) => {
      const t = (repo.timeValue - oldest) / span
      const radius = maxRadius - (maxRadius - minRadius) * t

      // Even distribution over 360 degrees ensures overlaps are mathematically impossible
      const angleDeg = index * (360 / count) - 90
      const angleRad = (angleDeg * Math.PI) / 180

      const x = CX + radius * Math.cos(angleRad)
      const y = CY + radius * Math.sin(angleRad)

      const ageDays = Math.max(0, Math.floor((now - repo.timeValue) / (1000 * 60 * 60 * 24)))

      return {
        ...repo,
        x,
        y,
        radius,
        relativeLabel: ageDays === 0 ? 'today' : ageDays === 1 ? 'yesterday' : `${ageDays}d ago`,
        coreSize,
        haloSize,
        langColor: getLanguageColor(repo.primaryLanguage),
      }
    })
  })

  // Context-aware active colors
  const currentActiveColor = $derived.by(() => {
    if (viewMode === 'orbit' && hoveredOrbitNode !== null)
      return mappedOrbitNodes[hoveredOrbitNode]?.langColor || 'rgba(196, 167, 231, 0.18)'

    if (pie.hovered !== null) 
      return pie.slices[pie.hovered]?.color || 'rgba(196, 167, 231, 0.18)'

    return 'rgba(196, 167, 231, 0.18)'
  })
</script>

