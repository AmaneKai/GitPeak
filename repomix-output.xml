}

/* =========================================
   AESTHETICS & BACKGROUNDS
   ========================================= */

.aurora-bg {
  position: fixed;
  inset: 0;
  z-index: -10;
  background-color: var(--base);
  overflow: hidden;
}

.aurora-bg::before,
.aurora-bg::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  animation: drift 25s ease-in-out infinite;
}

.aurora-bg::before {
  width: 70vw;
  height: 70vw;
  top: -20%;
  left: -10%;
  background: radial-gradient(circle, color-mix(in srgb, var(--iris) 12%, transparent) 0%, transparent 70%);
  animation-duration: 20s;
}

.aurora-bg::after {
  width: 60vw;
  height: 60vw;
  bottom: -15%;
  right: -10%;
  background: radial-gradient(circle, color-mix(in srgb, var(--foam) 10%, transparent) 0%, transparent 70%);
  animation-duration: 28s;
  animation-direction: reverse;
}

.glass {
  background: color-mix(in srgb, var(--surface) 60%, transparent);
  backdrop-filter: blur(20px) saturate(160%);
  -webkit-backdrop-filter: blur(20px) saturate(160%);
  border: 1px solid color-mix(in srgb, var(--subtle) 15%, transparent);
  box-shadow:
    0 1px 0 0 color-mix(in srgb, var(--text) 6%, transparent) inset,
    0 32px 64px -16px rgba(0, 0, 0, 0.45);
}

.gradient-text {
  color: var(--iris);
  background: linear-gradient(135deg, var(--iris) 0%, var(--foam) 50%, var(--rose) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* =========================================
   ANIMATIONS & INTERACTIONS
   ========================================= */

@keyframes drift {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(40px, -60px) scale(1.08); }
  66% { transform: translate(-30px, 40px) scale(0.95); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.5s ease both;
}

@keyframes barGrow {
  from { clip-path: inset(0 100% 0 0); }
  to { clip-path: inset(0 0% 0 0); }
}

.bar-grow {
  animation: barGrow 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes pulseDot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

.pulse-dot {
  animation: pulseDot 1.4s ease-in-out infinite;
}

.shimmer {
  position: relative;
  overflow: hidden;
  isolation: isolate;
  background: color-mix(in srgb, var(--surface) 60%, transparent);
  border: 1px solid color-mix(in srgb, var(--highlight-med) 10%, transparent);
}

.shimmer::after {
  content: "";
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 25%;
  pointer-events: none;
  background: linear-gradient(
    90deg,
    transparent 0%,
    color-mix(in srgb, var(--iris) 11%, transparent) 40%,
    color-mix(in srgb, var(--text) 15%, transparent) 50%,
    color-mix(in srgb, var(--iris) 11%, transparent) 60%,
    transparent 100%
  );
  animation: shimmer 2s ease-in-out infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}

/* =========================================
   COMPONENT SPECIFIC EFFECTS
   ========================================= */

/* StatGrid Tilt Cards */
.tilt-card {
  will-change: transform;
  transition: transform 0.1s ease, box-shadow 0.1s ease, border-color 0.1s ease;
  touch-action: manipulation;
}

.tilt-shine {
  pointer-events: none;
  position: absolute;
  inset: 0;
  border-radius: inherit;
}

/* LanguagePie / Orbit Animations */
@keyframes rowIn {
  from {
    opacity: 0;
    transform: translateX(-4px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.lang-path-group,
.orbit-path-group {
  transition: opacity 0.25s ease-in-out;
  will-change: opacity;
}

.arc-path {
  cursor: pointer;
  transition: opacity 0.18s ease, filter 0.18s ease;
  touch-action: manipulation;
}

.arc-path.dimmed {
  opacity: 0.16;
  filter: saturate(0.12);
}

.lang-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 4px 6px;
  border-radius: 8px;
  cursor: default;
  user-select: none;
  transition: background-color 0.2s ease, transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
  touch-action: manipulation;
  animation: rowIn 0.3s ease backwards;
  will-change: transform;
}

.lang-row:hover,
.lang-row.active {
  transform: translateX(1.5px);
}

.pfp-button-group {
  transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
  will-change: transform;
}

.pfp-button-group:hover {
  transform: translateY(-2.5px);
}

.pfp-button-group:active {
  transform: translateY(1px);
}

.icon-badge {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
  will-change: transform;
}

.lang-row:hover .icon-badge,
.lang-row.active .icon-badge {
  transform: scale(1.04);
}

.icon-badge img {
  width: 13px;
  height: 13px;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.6;
  transition: opacity 0.2s ease;
}

.lang-row:hover .icon-badge img,
.lang-row.active .icon-badge img {
  filter: none;
  opacity: 1;
}

.fade-in {
  animation: rowIn 0.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* =========================================
   SCROLLBARS
   ========================================= */

::-webkit-scrollbar { 
  width: 6px; 
}

::-webkit-scrollbar-track { 
  background: transparent; 
}

::-webkit-scrollbar-thumb { 
  background-color: var(--highlight-med); 
  border-radius: 99px; 
}

.legend-list {
  max-height: 236px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(144, 140, 170, 0.16) transparent;
  touch-action: pan-y;
}

.legend-list::-webkit-scrollbar {
  width: 3px;
}

.legend-list::-webkit-scrollbar-thumb {
  background: rgba(144, 140, 170, 0.16);
  border-radius: 99px;
}
