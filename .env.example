# GitPeak Environment Variables
# Copy this file to .env and update the values

# API endpoint for GitHub stats worker
GITHUB_STATS_API_URL=https://portfolio-github-stats.carlosranara.workers.dev

# Rate limiting for the public image endpoints (/og, /api/readme, /wallpaper) — each
# request calls the GitHub stats worker above, so these guard against username-enumeration
# abuse. Create a free Redis database at https://upstash.com, then copy the REST URL and
# REST token from its dashboard. If left unset, rate limiting is disabled (logs a warning).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
